R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Meta / Instagram Graph API ---
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

