FROM nginx:alpine
RUN rm -rf /usr/share/nginx/html/*
COPY ["nicho ingles/rodgerkoller/site/", "/usr/share/nginx/html/"]
COPY ["nicho ingles/rodgerkoller/site/nginx.conf", "/etc/nginx/conf.d/default.conf"]
RUN rm -f /usr/share/nginx/html/Dockerfile /usr/share/nginx/html/nginx.conf /usr/share/nginx/html/netlify.toml && rm -rf /usr/share/nginx/html/.netlify /usr/share/nginx/html/node_modules /usr/share/nginx/html/package*.json && find /usr/share/nginx/html/assets -name '*.png' -delete 2>/dev/null; true
EXPOSE 80
